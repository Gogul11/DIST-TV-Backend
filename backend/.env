PORT=4000
HOST=0.0.0.0
CORS_ORIGIN=*
BASE_MEDIA_DIR=/home/jarvis/Test-TV

# Which player to use: vlc (default) or mpv
PLAYER=vlc

# Optional: path to VLC executable (must be installed).
# On Linux/macOS it's usually `vlc`, on some servers you may use `cvlc`.
# VLC_PATH=vlc

# Optional: path to mpv executable (if PLAYER=mpv).
# MPV_PATH=mpv

# Optional: default duration for images during playback
IMAGE_DURATION_SECONDS=5

# Optional: max upload size in MB
MAX_UPLOAD_MB=1024

# Optional: start player in fullscreen
PLAYER_FULLSCREEN=true
